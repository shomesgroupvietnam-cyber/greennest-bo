# App
NEXT_PUBLIC_APP_NAME="GreenNest BuildFlow"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Mock auth/RBAC for local development before Supabase Auth is integrated.
# Any role key from blueprint/12-auth-roles-permissions.md is valid.
MOCK_CURRENT_ROLE="admin"
NEXT_PUBLIC_MOCK_ROLE="admin"

# Supabase
# mock keeps local JSON persistence even if Supabase variables are present.
# supabase uses Supabase repositories. Leave empty to auto-select:
# - mock when Supabase public variables are missing
# - supabase when Supabase public variables are configured
GREENNEST_REPOSITORY_MODE=""
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
ALLOW_STAGING_WRITES="false"

# Database, optional if using direct Prisma/SQL tooling later
DATABASE_URL=""

# AI
# mock is the safe local/default provider.
# auto uses OpenAI-compatible only when OPENAI_API_KEY is set, otherwise mock.
AI_PROVIDER="mock"
AI_CHAT_MODEL="gpt-4.1-mini"
AI_MAX_OUTPUT_TOKENS="700"
AI_TEMPERATURE="0.2"
AI_PROVIDER_TIMEOUT_MS="20000"
AI_PROVIDER_MAX_RETRIES="2"
AI_EMBEDDING_PROVIDER="mock"
AI_EMBEDDING_MODEL="text-embedding-3-small"
AI_EMBEDDING_DIMENSIONS="1536"
WEB_SEARCH_PROVIDER="mock"
WEB_SEARCH_API_KEY=""
WEB_SEARCH_MAX_RESULTS="6"
WEB_SEARCH_TIMEOUT_MS="12000"
DISCOVERY_RUNNER_ID="local-discovery-runner"
OPENAI_API_KEY=""
